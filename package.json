{
  "name": "nextjs-admin-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check-format": "prettier --check .",
    "check-types": "tsc --pretty --noEmit",
    "format": "prettier --write .",
    "clean": "npx rimraf .next dist build out node_modules",
    "bootstrap": "npm run clean && npm install && npm run env:local",
    "bootstrap:ci": "npm run clean && npm ci && npm run env:local",
    "dev": "next dev --webpack",
    "env": "npm run env:local",
    "env:local": "shx cp -f env/.env.local .env",
    "env:prod": "shx cp -f env/.env.prod .env",
    "env:staging": "shx cp -f env/.env.staging .env",
    "env:test": "shx cp -f env/.env.test .env",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix --max-warnings=0",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx|json|css|scss|md)": [
      "npx prettier --write",
      "npx eslint --fix --ext .js,.jsx,.ts,.tsx"
    ]
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@hookform/resolvers": "^5.4.0",
    "@react-jvectormap/core": "^1.0.4",
    "@react-jvectormap/world": "^1.1.2",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "apexcharts": "^5.14.0",
    "axios": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "flatpickr": "^4.6.13",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "moment": "^2.30.1",
    "next": "16.2.7",
    "next-cloudinary": "^6.17.5",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.10",
    "nuqs": "^2.8.9",
    "pino": "^10.3.1",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-apexcharts": "^2.1.0",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.77.0",
    "rimraf": "^6.1.3",
    "server-only": "^0.0.1",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/css": "^1.3.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prettier-plugin-classnames": "^0.10.2",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shx": "^0.4.0",
    "tailwind-csstree": "^0.3.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "@react-jvectormap/core": {
      "react": "^16.8.0 || ^17 || ^18 || ^19",
      "react-dom": "^16.8.0 || ^17 || ^18 || ^19"
    },
    "@react-jvectormap/world": {
      "react": "^16.8.0 || ^17 || ^18 || ^19",
      "react-dom": "^16.8.0 || ^17 || ^18 || ^19"
    }
  }
}
